# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://bjhokdrgjyqhhccpuoaa.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only keys (NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Service
RESEND_API_KEY=your_resend_api_key

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token

# Mystifly
MYSTIFLY_USERNAME=your_mystifly_username
MYSTIFLY_PASSWORD=your_mystifly_password
MYSTIFLY_ACCOUNT_NUMBER=your_mystifly_account_number
MYSTIFLY_BASE_URL=https://restapidemo.myfarebox.com

# Duffel
DUFFEL_ACCESS_TOKEN=your_duffel_access_token

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Places API (for POI preview images)
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Markup pricing (see src/lib/pricing.ts for full strategy documentation)
# Flights: 8% — must stay low; transparent market vs Google Flights/Kayak
# Hotels:  15% — OTA industry standard; hotel prices are opaque across platforms
FLIGHT_MARKUP_PERCENTAGE=0.08
HOTEL_MARKUP_PERCENTAGE=0.15

# TravelGateX
TRAVELGATEX_API_KEY=your_travelgatex_api_key
# TEST: 2 (default_HOTELTEST) | PROD: 37606 (FORHU INC - FastX)
TRAVELGATEX_CODE=2
TRAVELGATEX_ENDPOINT_URL=https://api.travelgate.com

# ONDA Channel Partner API
ONDA_API_KEY=your_onda_api_key
ONDA_BASE_URL=https://dapi.tport.dev
ONDA_DEV_PROPERTY_IDS=

# Google Search Console verification token
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Site URL (set to your production domain in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
